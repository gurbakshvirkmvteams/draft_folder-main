{% style %}
.custom-product-gift-wrapper {
  display: flex;
  flex-direction: column;
  gap: 20px;
  align-items: center;
  justify-content: center;
}
.gift-section-heading {
  font-size: clamp(18px, 2vw, 28px);
  font-weight: 700;
  margin: 0 0 20px;
}
.custom-product-gift {
  display: flex;
  justify-content: center;
  gap: 30px;
  background-color: #f5f5f5;
  max-width: 700px;
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}
.custom-product-gift-text {
  display: flex;
  flex-direction: column;
  max-width: 400px;
}
.custom-product-gift-text h2 {
  font-size: clamp(20px, 2.5vw, 24px);
  font-weight: 600;
  margin: 0 0 10px;
}
.custom-product-gift-text p {
  font-size: clamp(16px, 2vw, 18px);
  font-weight: 500;
  margin: 0 0 5px;
}
.custom-product-gift-text ul {
  list-style-type: none; 
  padding-left: 0;
  margin: 0;
}
@media (max-width: 576px) {
  .custom-product-gift {
    gap: 20px;
  }
  .custom-product-gift{
    flex-direction: column;
    align-items: center;
  }
}
{% endstyle %}

{% if product.metafields.custom.gifts.value != blank %}
  <div class="custom-product-gift-wrapper custom-page-width" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    <h2 class="gift-section-heading">Gift Included</h2>
    <div class="custom-product-gift">
      {% assign gift = product.metafields.custom.gifts.value %}
      {% if gift.image %}
        {{ gift.image | image_url: width: 200 | image_tag }}
      {% endif %}
      <div class="custom-product-gift-text">
        <h2>{{ gift.title }}</h2>
        <p>Price: {{ gift.price }}</p>
        <ul>
          {% for feature in gift.features.value %}
            <li>{{ feature }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
  {
    "name": "Product Metaobjects",
    "settings": [
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }
    ],
    "presets": [
      {
        "name": "Product Metafields"
      }
    ]
  }
{% endschema %}