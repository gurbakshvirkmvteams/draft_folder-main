<link rel="stylesheet" href="{{ 'ingredient.css' | asset_url }}" media="print" onload="this.media='all'">

<div
  class="ingredien-section-wrapper"
  style="
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  "
>

  {% for block in section.blocks %}
    <div class="custom-page-width">
      {% case block.type %}
        {% when 'heading' %}
          <div class="ingredient-science-label">
            <p>{{ section.settings.label }}</p>
          </div>

          <h2
            class="ingredient-section-heading"
            style="
              font-size:{{ block.settings.heading_font_size }}px;
              color: {{ block.settings.heading_text_color }};
              text-transform: {{ block.settings.text_transform }};
            "
          >
            {{ block.settings.heading }}
          </h2>
        {% when 'description' %}
          <p class="ingredient-section-description">{{ block.settings.description }}</p>
      {% endcase -%}
    </div>
  {%- endfor -%}
  <div class="ingredient-tab-button-container custom-page-width">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'tab' %}
          <button class="ingredient-tab-button" data-tab="{{ block.settings.tab_title }}">
            {{ block.settings.tab_title }}
          </button>
      {% endcase %}
    {% endfor %}
  </div>
  <div class="ingredient-cards-container custom-page-width">
    {% assign tab_index = 0 %}

    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'tab' %}
          {% assign tab_index = tab_index | plus: 1 %}
          <div class="ingredient-card" data-tab="{{ block.settings.tab_title }}" data-index="{{ tab_index }}">
            <div class="ingredient-card-title" data-index="{{ tab_index }}">{{ block.settings.title }}</div>
            <div class="">{{ block.settings.description }}</div>
            <button class="next-card-button" data-index="{{ tab_index }}">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</div>
<script>
  const tabButtons = document.querySelectorAll('.ingredient-tab-button');
  const cards = document.querySelectorAll('.ingredient-card');
  const nextCardButtons = document.querySelectorAll('.next-card-button');

  const removeActiveClass = () => {
    cards.forEach((card) => {
      card.classList.remove('active-tab');
    });
    tabButtons.forEach((btn) => btn.classList.remove('active-btn'));
  };
  cards[0].classList.add('active-tab');
  tabButtons[0].classList.add('active-btn');
  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      removeActiveClass();
      button.classList.add('active-btn');
      const buttonData = button.getAttribute('data-tab');
      cards.forEach((card) => {
        const target = card.getAttribute('data-tab');
        if (target === buttonData) {
          card.classList.add('active-tab');
        }
      });
    });
  });

  nextCardButtons.forEach((button) => {
    button.addEventListener('click', () => {
      removeActiveClass();
      const value = button.getAttribute('data-index');
      if (value < cards.length) {
        cards[value].classList.add('active-tab');
        tabButtons[value].classList.add('active-btn');
      } else {
        cards[0].classList.add('active-tab');
        tabButtons[0].classList.add('active-btn');
      }
    });
  });
</script>

{% schema %}
{
  "name": "Ingredient Details",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Ingredient Science"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "name": "Add a heading",
      "type": "heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading Text",
          "default": "Ingredient Heading"
        },
        {
          "type": "range",
          "id": "heading_font_size",
          "label": "Font Size",
          "min": 16,
          "max": 72,
          "step": 1,
          "unit": "px",
          "default": 32
        },
        {
          "type": "color",
          "id": "heading_text_color",
          "label": "Text Color",
          "default": "#000000"
        },
        {
          "type": "select",
          "id": "text_transform",
          "label": "Text Transform",
          "default": "uppercase",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "uppercase",
              "label": "UPPERCASE"
            },
            {
              "value": "lowercase",
              "label": "lowercase"
            },
            {
              "value": "capitalize",
              "label": "Capitalize"
            }
          ]
        }
      ]
    },
    {
      "name": "Add a Description",
      "type": "description",
      "settings": [
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Description"
        }
      ]
    },
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ingredient Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Details"
    }
  ]
}
{% endschema %}
