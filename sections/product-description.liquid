{%- style -%}
  .product-description-section {
    padding: 64px 0;
  }

  .product-description-wrapper {
    margin: 0 auto;
    padding: 0 20px;
    max-width: 1156px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 42px;
  }

  .product-description-content {
    display: flex;
    flex-direction: column;
    padding-top: 40px;
  }

  .product-description-title {
    font-size: 28px;
    font-weight: 700;
    color: #111;
    margin: 0 0 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid #67696E;
  }

  .product-description-text {
    color: #666;
    font-size: 16px;
    line-height: 1.7;
  }

  .product-description-text ul {
    margin-top: 20px;
    padding-left: 18px;
  }

  .product-description-text li {
    margin-bottom: 8px;
  }

  .product-description-image {
    overflow: hidden;
    background: #f5f5f5;
    max-height: 373px;
    border-radius: 20px;
  }

  .product-description-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .product-description-section {
      padding: 50px 20px;
    }

    .product-description-wrapper {
      grid-template-columns: 1fr;
    }

    .product-description-title {
      font-size: 24px;
    }

    .product-description-image {
      min-height: 300px;
    }
  }
  @media (max-width: 576px) {
    .product-description-content h2 {
      font-weight: 700;
      font-size: 20px;
      line-height: 24px;
      letter-spacing: -0.5px;
    }
    .product-description-text {
      font-weight: 400;
      font-size: 16px;
      line-height: 20px;
      letter-spacing: 0;
    }
    .product-description-title {
      margin: 0;
    }
    .product-description-text {
      font-size: 16px;
      line-height: 20px;
    }
  }
{%- endstyle -%}

<section class="product-description-section">
    <div class="product-description-wrapper">
      <div class="product-description-content">
        <h2 class="product-description-title">
          {{ section.settings.heading }}
        </h2>

        <div class="product-description-text">
          {{ product.description }}
        </div>
      </div>

      <div class="product-description-image">
        {% if section.settings.image != blank %}
          {{
            product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400,600,800', alt: section.settings.heading
          }}
        {% endif %}
      </div>
  </div>
</section>

{% schema %}
  {
    "name": "Product Description",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Description"
      }, {
        "type": "richtext",
        "id": "description",
        "label": "Description",
        "default": "<p>Energize your look with a fresh take on heritage adidas style. The adidas Daily 3.0 Shoes cut a classic profile with a modern suede upper.</p><ul><li>Regular fit</li><li>Lace closure</li><li>Rubber outsole with vulcanized look</li><li>Imported</li></ul>"
      }, {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      }
    ],
    "presets": [
      {
        "name": "Product Description"
      }
    ]
  }
{% endschema %}