        },
        "faq_F833pq": {
          "type": "faq",
          "settings": {
            "question": "Saltwater okay?",
            "answer": "<p>Yes. The PVC and EVA materials are suitable for both freshwater and saltwater use. For longest lifespan, rinse the ramp with clean water after saltwater exposure and allow it to dry before storage</p>"
