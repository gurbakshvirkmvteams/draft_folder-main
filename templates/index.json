        "faq_Jhk9YL": {
          "type": "faq",
          "settings": {
            "question": "Does it work for senior or arthritic dogs?",
            "answer": "<p>Yes. The submerged mesh entry and EVA non-slip surface help older or arthritic dogs enter the ramp gradually instead of needing to jump. Many owners use these ramps specifically to reduce lifting strain and joint stress</p>"
